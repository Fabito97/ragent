# Copy this file to .env and fill in your real values

# Groq API Key (required) — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Storage paths
UPLOAD_DIR=./uploads
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=enterprise_docs

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Retrieval
TOP_K_RESULTS=5

# Models
LLM_MODEL=openai/gpt-oss-120b
EMBEDDING_MODEL=all-MiniLM-L6-v2

# File safety
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt,csv,xlsx,xls
